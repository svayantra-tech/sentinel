# ── Sentinel configuration (12-Factor: all config via env — NFR-06) ──────────
# Copy to .env.local and fill in. Every value has a safe default or fallback.

# LLM — primary provider (Featherless / any OpenAI-compatible endpoint)
LLM_BASE_URL=https://api.featherless.ai/v1
LLM_API_KEYS=key1,key2,key3            # comma-separated; auto-rotated on 429/5xx
LLM_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# LLM — fallback provider (Groq / Gemini-OpenAI-compat / OpenAI)
LLM_FALLBACK_BASE_URL=https://api.groq.com/openai/v1
LLM_FALLBACK_API_KEYS=
LLM_FALLBACK_MODEL=llama-3.3-70b-versatile

# Demo determinism: "live" = real LLM · "scripted" = deterministic fault-injection
# (see docs/DEMO_SCRIPT.md — scripted mode guarantees reproducible safety-gate demos)
DEMO_MODE=live

# Qdrant (leave URL empty to run on the built-in in-memory vector store)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Embeddings — any OpenAI-compatible embeddings endpoint; empty = local hash embedder
EMBEDDINGS_URL=
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=

# Enkrypt AI (cloud guardrails; local deterministic guardrails ALWAYS run in parallel)
ENKRYPT_BASE_URL=https://api.enkryptai.com
ENKRYPT_API_KEY=

# Security (FR-13/NFR-03) — JWT signing secret; generate: openssl rand -hex 32
JWT_SECRET=change-me-in-production
DEMO_PASSWORD=sentinel-demo

# Observability (NFR-01) — OTLP endpoint (Jaeger from docker-compose)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Mastra workflow state store (Turso URL in prod; local file in dev — NFR-07)
MASTRA_DB_URL=file:./sentinel.db
